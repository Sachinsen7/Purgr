{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "build": {
        "beforeBuildCommand": "npm run build",
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:3000",
        "frontendDist": "../.output/public"
    },
    "bundle": {
        "active": true,
        "category": "DeveloperTool",
        "copyright": "",
        "linux": {
            "deb": {
                "depends": []
            }
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "longDescription": "",
        "macOS": {
            "entitlements": null,
            "exceptionDomain": "",
            "frameworks": [],
            "providerShortName": null,
            "signingIdentity": null
        },
        "resources": [],
        "shortDescription": "",
        "targets": "all",
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": ""
        }
    },
    "identifier": "com.devsweep.app",
    "plugins": {
        "shell": {
            "open": true
        }
    },
    "productName": "DevSweep",
    "version": "0.1.0",
    "app": {
        "windows": [
            {
                "title": "DevSweep",
                "width": 1280,
                "height": 800,
                "resizable": true,
                "fullscreen": false,
                "center": true
            }
        ]
    }
}